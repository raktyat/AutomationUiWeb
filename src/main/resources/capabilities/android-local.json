{
  "platformName": "Android",
  "appium:automationName": "UiAutomator2",
  "appium:deviceName": "Android Emulator",
  "appium:platformVersion": "13.0",
  "appium:app": "${android.app.path}",
  "appium:appPackage": "com.example.app",
