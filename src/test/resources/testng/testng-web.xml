<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Web Tests Suite" parallel="methods" thread-count="4" verbose="2">
    <listeners>
        <listener class-name="com.automation.framework.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Web Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.web"/>
        </packages>
    </test>

    <test name="Web Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.web"/>
        </packages>
    </test>
</suite>
