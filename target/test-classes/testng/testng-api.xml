<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Tests Suite" parallel="methods" thread-count="4" verbose="2">
    <listeners>
        <listener class-name="com.automation.framework.listeners.TestListener"/>
    </listeners>

    <test name="API Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.api"/>
        </packages>
    </test>

    <test name="API Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.api"/>
        </packages>
    </test>

    <test name="API Negative Tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.api"/>
        </packages>
    </test>
</suite>
