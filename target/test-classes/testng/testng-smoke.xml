<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Tests Suite" parallel="tests" thread-count="4" verbose="2">
    <listeners>
        <listener class-name="com.automation.framework.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Web Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.web"/>
        </packages>
    </test>

    <test name="API Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.automation.framework.tests.api"/>
        </packages>
    </test>
</suite>
