<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Mobile Tests Suite" parallel="tests" thread-count="2" verbose="2">
    <listeners>
        <listener class-name="com.automation.framework.listeners.TestListener"/>
    </listeners>

    <test name="Android Tests">
        <parameter name="platform" value="android"/>
        <packages>
            <package name="com.automation.framework.tests.mobile.android"/>
        </packages>
    </test>

    <test name="iOS Tests">
        <parameter name="platform" value="ios"/>
        <packages>
            <package name="com.automation.framework.tests.mobile.ios"/>
        </packages>
    </test>
</suite>
